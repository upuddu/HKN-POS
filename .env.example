# IMAP Configuration for Purdue / Office 365
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
EMAIL_ADDRESS=your-purdue-email@purdue.edu
EMAIL_PASSWORD=your-app-password

# Filters (defaults shown — override if needed)
TARGET_SENDER=BOSOFinance@Purdue.edu
TARGET_SUBJECT=TooCOOL Order Confirmation

# Downloads directory (relative to project root)
DOWNLOAD_DIR=downloads

# API Server
API_PORT=8042
API_PASSKEY=change-me-to-a-real-secret

# Webhook — the external server endpoint that receives interrupts
WEBHOOK_URL=http://localhost:9000/webhook/order
ACK_TIMEOUT=30

# SQLite database path
DB_PATH=hkn_pos.db
